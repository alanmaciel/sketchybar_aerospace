#!/usr/bin/env bash

CONFIG_DIR="${CONFIG_DIR:-$HOME/.config/sketchybar}"
PLUGIN_DIR="$CONFIG_DIR/plugins"

source "$CONFIG_DIR/themes.sh"


########################################
# BAR
########################################
sketchybar --bar \
  position=top \
  height=32 \
  blur_radius=30 \
  color="$BAR_BG"
  # border_color="$BAR_BORDER" \
  # border_width=1

########################################
# DEFAULTS
########################################
default=(
  icon.font="Hack Nerd Font:Bold:17.0"
  label.font="Hack Nerd Font:Bold:14.0"
  icon.color="$BAR_FG"
  label.color="$BAR_FG"
  padding_left=4
  padding_right=4
  label.padding_left=4
  label.padding_right=4
)
sketchybar --default "${default[@]}"

########################################
# AEROSPACE EVENT
########################################
sketchybar --add event aerospace_workspace_change
sketchybar --add event front_app_focus_changed

########################################
# LAPTOP ROW (1–5) → display 1, monitor 2
########################################

# Must match MAX_SLOTS in aerospace_workspaces_per_monitor.sh. Bump if you
# regularly have more windows open in a single workspace.
WORKSPACE_MAX_WINDOWS=10

SPACE_MON1=("1" "2" "3" "4" "5")

# Each pill is a bracket merging a "num" item (the workspace digit) with a
# fixed pool of "slot" items (one per potential window, up to
# WORKSPACE_MAX_WINDOWS). aerospace_workspaces_per_monitor.sh fills in one
# slot per window with that app's icon and colors the focused window's icon
# differently, so the bracket's members render as a single pill.
for sid in "${SPACE_MON1[@]}"; do
  sketchybar --add item "space1.$sid.num" left \
    --subscribe "space1.$sid.num" aerospace_workspace_change front_app_switched front_app_focus_changed \
    --set "space1.$sid.num" \
      associated_display=1 \
      icon="$sid" \
      icon.padding_left=10 \
      icon.padding_right=10 \
      label.drawing=off \
      click_script="aerospace workspace $sid" \
      script="$PLUGIN_DIR/aerospace_workspaces_per_monitor.sh $sid 2"

  SLOTS=()
  for i in $(seq 0 $((WORKSPACE_MAX_WINDOWS - 1))); do
    sketchybar --add item "space1.$sid.slot.$i" left \
      --set "space1.$sid.slot.$i" \
        associated_display=1 \
        drawing=off \
        icon.drawing=off \
        label.font="sketchybar-app-font:Regular:16.0" \
        label.padding_left=0 \
        label.padding_right=0
    SLOTS+=("space1.$sid.slot.$i")
  done

  sketchybar --add bracket "space1.$sid" "space1.$sid.num" "${SLOTS[@]}" \
    --set "space1.$sid" \
      background.color="$SPACE_BG" \
      background.corner_radius=5 \
      background.height=22 \
      background.drawing=on

  # Brackets ignore their own padding for spacing, so a plain spacer item is
  # the only way to put a visible gap between two pills.
  sketchybar --add item "space1.$sid.gap" left \
    --set "space1.$sid.gap" associated_display=1 icon.drawing=off label.drawing=off width=8
done


########################################
# EXTERNAL ROW (6–0) → display 2, monitor 1
########################################
SPACE_MON2=("6" "7" "8" "9" "0")

for sid in "${SPACE_MON2[@]}"; do
  sketchybar --add item "space2.$sid.num" left \
    --subscribe "space2.$sid.num" aerospace_workspace_change front_app_switched front_app_focus_changed \
    --set "space2.$sid.num" \
      associated_display=2 \
      icon="$sid" \
      icon.padding_left=10 \
      icon.padding_right=10 \
      label.drawing=off \
      click_script="aerospace workspace $sid" \
      script="$PLUGIN_DIR/aerospace_workspaces_per_monitor.sh $sid 1"

  SLOTS=()
  for i in $(seq 0 $((WORKSPACE_MAX_WINDOWS - 1))); do
    sketchybar --add item "space2.$sid.slot.$i" left \
      --set "space2.$sid.slot.$i" \
        associated_display=2 \
        drawing=off \
        icon.drawing=off \
        label.font="sketchybar-app-font:Regular:16.0" \
        label.padding_left=0 \
        label.padding_right=0
    SLOTS+=("space2.$sid.slot.$i")
  done

  sketchybar --add bracket "space2.$sid" "space2.$sid.num" "${SLOTS[@]}" \
    --set "space2.$sid" \
      background.color="$SPACE_BG" \
      background.corner_radius=5 \
      background.height=22 \
      background.drawing=on

  sketchybar --add item "space2.$sid.gap" left \
    --set "space2.$sid.gap" associated_display=2 icon.drawing=off label.drawing=off width=8
done


########################################
# RIGHT SIDE – DISPLAY 1 (Laptop)
########################################

sketchybar --add item clock right \
  --set clock \
      associated_display=1 \
      icon= \
      icon.color="$RIGHT_ICON" \
      label.color="$RIGHT_LABEL" \
      update_freq=15 \
      background.color="$SPACE_BG" \
      background.corner_radius=5 \
      background.height=24 \
      background.drawing=on \
      icon.padding_left=10 \
      icon.padding_right=4 \
      label.padding_left=2 \
      label.padding_right=10 \
      script="$PLUGIN_DIR/clock.sh" \
      click_script="$PLUGIN_DIR/clock.sh click"

