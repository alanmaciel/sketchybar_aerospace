########################################
# RIGHT SIDE – DISPLAY 2 (External)
########################################

sketchybar --add item clock_ext right \
  --set clock_ext \
      associated_display=2 \
      icon= \
      icon.color="$RIGHT_ICON" \
      label.color="$RIGHT_LABEL" \
